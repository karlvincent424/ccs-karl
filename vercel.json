{
  "version": 2,
  "rewrites": [
    {
      "source": "/(server|database|package|package-lock|vercel)\\.(js|json)",
      "destination": "/404"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/Login.html"
    },
    {
      "source": "/register",
      "destination": "/Register.html"
    },
    {
      "source": "/profile",
      "destination": "/Profile.html"
    },
    {
      "source": "/leaderboard",
      "destination": "/Leaderboard.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/history",
      "destination": "/history.html"
    },
    {
      "source": "/reservation",
      "destination": "/reservation.html"
    },
    {
      "source": "/sessions",
      "destination": "/sessions.html"
    },
    {
      "source": "/summary",
      "destination": "/summary.html"
    }
  ]
}
