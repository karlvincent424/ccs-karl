# Port for local development
PORT=3000

# Turso SQLite database configuration
# For local development with file-based SQLite, you can leave these blank or use:
# TURSO_DATABASE_URL=file:ccs_database.db
# For production/Vercel, replace with your remote Turso DB url (libsql://...) and authentication token
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=24h

# Environment setting (production, development)
NODE_ENV=development
